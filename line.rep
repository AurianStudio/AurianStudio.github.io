// ============================================================================
//  RESOURCE LOADER
// ============================================================================
class ResourceLoader {
public:
    static ID3D11ShaderResourceView* LoadTextureFromResource(ID3D11Device* device, int resourceId, int& outWidth, int& outHeight) {
        HRSRC hResource = FindResource(NULL, MAKEINTRESOURCE(resourceId), "PNG");
        if (!hResource) return nullptr;

        HGLOBAL hMemory = LoadResource(NULL, hResource);
        if (!hMemory) return nullptr;

        DWORD size = SizeofResource(NULL, hResource);
        void* data = LockResource(hMemory);

        int width, height, channels;
        unsigned char* pixels = stbi_load_from_memory((unsigned char*)data, size, &width, &height, &channels, 4);
        if (!pixels) return nullptr;

        D3D11_TEXTURE2D_DESC desc = {};
        desc.Width = width;
        desc.Height = height;
        desc.MipLevels = 1;
        desc.ArraySize = 1;
        desc.Format = DXGI_FORMAT_R8G8B8A8_UNORM;
        desc.SampleDesc.Count = 1;
        desc.Usage = D3D11_USAGE_DEFAULT;
        desc.BindFlags = D3D11_BIND_SHADER_RESOURCE;

        D3D11_SUBRESOURCE_DATA initData = {};
        initData.pSysMem = pixels;
        initData.SysMemPitch = width * 4;

        ID3D11Texture2D* texture = nullptr;
        device->CreateTexture2D(&desc, &initData, &texture);

        ID3D11ShaderResourceView* srv = nullptr;
        if (texture) {
            D3D11_SHADER_RESOURCE_VIEW_DESC srvDesc = {};
            srvDesc.Format = desc.Format;
            srvDesc.ViewDimension = D3D11_SRV_DIMENSION_TEXTURE2D;
            srvDesc.Texture2D.MipLevels = 1;
            device->CreateShaderResourceView(texture, &srvDesc, &srv);
            texture->Release();
        }

        stbi_image_free(pixels);
        outWidth = width;
        outHeight = height;
        return srv;
    }
};

