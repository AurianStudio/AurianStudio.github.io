// ============================================================================
//  LOGGING SYSTEM
// ============================================================================
enum class LogType { Info, Success, Error, Warning };

struct LogEntry {
    LogType type;
    std::string message;
    std::chrono::system_clock::time_point timestamp;
};

class Logger {
private:
    std::vector<LogEntry> m_Logs;
    std::mutex m_Mutex;
    bool m_AutoScroll = true;

    static const char* GetPrefix(LogType type) {
        switch (type) {
            case LogType::Success: return "[+]";
            case LogType::Error:   return "[-]";
            case LogType::Warning: return "[!]";
            default:               return "[*]";
        }
    }

    static ImU32 GetColor(LogType type) {
        switch (type) {
            case LogType::Success: return AurianColors::Success;
            case LogType::Error:   return AurianColors::Error;
            case LogType::Warning: return AurianColors::Warning;
            default:               return AurianColors::TextSecondary;
        }
    }

public:
    void Log(LogType type, const std::string& message) {
        std::lock_guard<std::mutex> lock(m_Mutex);
        m_Logs.push_back({ type, message, std::chrono::system_clock::now() });
        if (m_Logs.size() > 500) m_Logs.erase(m_Logs.begin());
    }

    void Render() {
        std::lock_guard<std::mutex> lock(m_Mutex);
        
        ImGui::PushStyleVar(ImGuiStyleVar_ItemSpacing, ImVec2(4, 2));
        
        for (const auto& entry : m_Logs) {
            ImGui::PushStyleColor(ImGuiCol_Text, GetColor(entry.type));
            ImGui::TextUnformatted(GetPrefix(entry.type));
            ImGui::SameLine();
            ImGui::TextUnformatted(entry.message.c_str());
            ImGui::PopStyleColor();
        }
        
        ImGui::PopStyleVar();
        
        if (m_AutoScroll && ImGui::GetScrollY() >= ImGui::GetScrollMaxY())
            ImGui::SetScrollHereY(1.0f);
    }

    void Clear() {
        std::lock_guard<std::mutex> lock(m_Mutex);
        m_Logs.clear();
    }
};

inline Logger g_Logger;

// ============================================================================
//  CONFIGURATION SYSTEM
// ============================================================================
struct ModuleConfig {
    bool enabled = false;
    std::map<std::string, float> floatSettings;
    std::map<std::string, int> intSettings;
    std::map<std::string, std::string> stringSettings;
};

struct UserProfile {
    std::string username;
    std::string licenseKey;
    std::string plan;
    std::string expiry;
    std::string hwid;
};

struct AurianConfig {
    UserProfile user;
    std::map<std::string, ModuleConfig> modules;
    std::map<std::string, int> keybinds;
    std::vector<std::string> friends;
    std::string activeProfile = "Default";
    std::string theme = "Default";
    
    // GUI settings
    float windowOpacity = 0.95f;
    bool blurEnabled = true;
};

class ConfigManager {
private:
    fs::path m_ConfigDir;
    fs::path m_ProfilesDir;
    fs::path m_SettingsFile;
    AurianConfig m_Config;

    void EnsureDirectories() {
        m_ConfigDir = fs::path(getenv("APPDATA")) / "AurianClient";
        m_ProfilesDir = m_ConfigDir / "profiles";
        m_SettingsFile = m_ConfigDir / "settings.json";
        
        fs::create_directories(m_ConfigDir);
        fs::create_directories(m_ProfilesDir);
    }

public:
    void Initialize() {
        EnsureDirectories();
        LoadSettings();
        g_Logger.Log(LogType::Success, "Config system initialized");
    }

    void LoadSettings() {
        if (!fs::exists(m_SettingsFile)) {
            SaveSettings();
            return;
        }

        try {
            std::ifstream file(m_SettingsFile);
            json j = json::parse(file);
            
            if (j.contains("user")) {
                m_Config.user.username = j["user"].value("username", "");
                m_Config.user.licenseKey = j["user"].value("licenseKey", "");
                m_Config.user.plan = j["user"].value("plan", "");
                m_Config.user.expiry = j["user"].value("expiry", "");
                m_Config.user.hwid = j["user"].value("hwid", "");
            }
            
            m_Config.activeProfile = j.value("activeProfile", "Default");
            m_Config.theme = j.value("theme", "Default");
            m_Config.windowOpacity = j.value("windowOpacity", 0.95f);
            m_Config.blurEnabled = j.value("blurEnabled", true);

            if (j.contains("keybinds")) {
                for (auto& [key, value] : j["keybinds"].items()) {
                    m_Config.keybinds[key] = value.get<int>();
                }
            }

            if (j.contains("friends")) {
                m_Config.friends = j["friends"].get<std::vector<std::string>>();
            }
        }
        catch (const json::exception& e) {
            g_Logger.Log(LogType::Error, std::string("Config parse error: ") + e.what());
        }
    }

    void SaveSettings() {
        json j;
        
        j["user"]["username"] = m_Config.user.username;
        j["user"]["licenseKey"] = m_Config.user.licenseKey;
        j["user"]["plan"] = m_Config.user.plan;
        j["user"]["expiry"] = m_Config.user.expiry;
        j["user"]["hwid"] = m_Config.user.hwid;
        j["activeProfile"] = m_Config.activeProfile;
        j["theme"] = m_Config.theme;
        j["windowOpacity"] = m_Config.windowOpacity;
        j["blurEnabled"] = m_Config.blurEnabled;
        
        j["keybinds"] = m_Config.keybinds;
        j["friends"] = m_Config.friends;

        std::ofstream file(m_SettingsFile);
        file << j.dump(4);
    }

    void SaveProfile(const std::string& name) {
        json j;
        j["modules"] = json::object();
        
        for (auto& [modName, modConfig] : m_Config.modules) {
            json mod;
            mod["enabled"] = modConfig.enabled;
            mod["floats"] = modConfig.floatSettings;
            mod["ints"] = modConfig.intSettings;
            mod["strings"] = modConfig.stringSettings;
            j["modules"][modName] = mod;
        }
        
        j["keybinds"] = m_Config.keybinds;
        j["friends"] = m_Config.friends;

        fs::path profilePath = m_ProfilesDir / (name + ".json");
        std::ofstream file(profilePath);
        file << j.dump(4);
        
        g_Logger.Log(LogType::Success, "Profile saved: " + name);
    }

    void LoadProfile(const std::string& name) {
        fs::path profilePath = m_ProfilesDir / (name + ".json");
        if (!fs::exists(profilePath)) {
            g_Logger.Log(LogType::Error, "Profile not found: " + name);
            return;
        }

        try {
            std::ifstream file(profilePath);
            json j = json::parse(file);

            if (j.contains("modules")) {
                for (auto& [modName, modJson] : j["modules"].items()) {
                    m_Config.modules[modName].enabled = modJson.value("enabled", false);
                    if (modJson.contains("floats")) {
                        for (auto& [key, val] : modJson["floats"].items())
                            m_Config.modules[modName].floatSettings[key] = val.get<float>();
                    }
                    if (modJson.contains("ints")) {
                        for (auto& [key, val] : modJson["ints"].items())
                            m_Config.modules[modName].intSettings[key] = val.get<int>();
                    }
                    if (modJson.contains("strings")) {
                        for (auto& [key, val] : modJson["strings"].items())
                            m_Config.modules[modName].stringSettings[key] = val.get<std::string>();
                    }
                }
            }

            if (j.contains("keybinds")) {
                for (auto& [key, val] : j["keybinds"].items())
                    m_Config.keybinds[key] = val.get<int>();
            }

            if (j.contains("friends"))
                m_Config.friends = j["friends"].get<std::vector<std::string>>();

            m_Config.activeProfile = name;
            SaveSettings();
            g_Logger.Log(LogType::Success, "Profile loaded: " + name);
        }
        catch (const json::exception& e) {
            g_Logger.Log(LogType::Error, std::string("Profile load error: ") + e.what());
        }
    }

    std::vector<std::string> GetProfileList() {
        std::vector<std::string> profiles;
        for (const auto& entry : fs::directory_iterator(m_ProfilesDir)) {
            if (entry.path().extension() == ".json") {
                profiles.push_back(entry.path().stem().string());
            }
        }
        return profiles;
    }

    AurianConfig& GetConfig() { return m_Config; }
};

inline ConfigManager g_Config;

// ============================================================================
//  HWID GENERATION
// ============================================================================
class HWIDGenerator {
public:
    static std::string Generate() {
        std::string hwid;
        
        // CPU ID
        int cpuInfo[4] = { 0 };
        __cpuid(cpuInfo, 0);
        for (int i = 0; i < 4; i++) {
            hwid += std::to_string(cpuInfo[i]) + "-";
        }

        // Volume serial number (C:)
        DWORD volumeSerial = 0;
        GetVolumeInformationA("C:\\", nullptr, 0, &volumeSerial, nullptr, nullptr, nullptr, 0);
        hwid += std::to_string(volumeSerial) + "-";

        // Motherboard baseboard serial
        HKEY hKey;
        if (RegOpenKeyExA(HKEY_LOCAL_MACHINE, 
            "HARDWARE\\DESCRIPTION\\System\\BIOS\\BaseBoard", 0, KEY_READ, &hKey) == ERROR_SUCCESS) {
            char serial[256] = { 0 };
            DWORD size = sizeof(serial);
            RegQueryValueExA(hKey, "SerialNumber", nullptr, nullptr, (LPBYTE)serial, &size);
            hwid += serial;
            RegCloseKey(hKey);
        }

        // Simple hash to normalize length
        std::hash<std::string> hasher;
        return std::to_string(hasher(hwid));
    }
};

// ============================================================================
//  AUTHENTICATION SYSTEM
// ============================================================================
class AuthSystem {
private:
    std::string m_ApiEndpoint = "https://api.aurianclient.com/v1";
    std::string m_SessionToken;
    bool m_IsAuthenticated = false;

    static size_t WriteCallback(void* contents, size_t size, size_t nmemb, std::string* userp) {
        size_t totalSize = size * nmemb;
        userp->append((char*)contents, totalSize);
        return totalSize;
    }

    bool MakeRequest(const std::string& endpoint, const json& payload, json& response) {
        CURL* curl = curl_easy_init();
        if (!curl) return false;

        std::string url = m_ApiEndpoint + endpoint;
        std::string payloadStr = payload.dump();
        std::string responseData;

        struct curl_slist* headers = nullptr;
        headers = curl_slist_append(headers, "Content-Type: application/json");
        headers = curl_slist_append(headers, "User-Agent: AurianLoader/1.0");

        curl_easy_setopt(curl, CURLOPT_URL, url.c_str());
        curl_easy_setopt(curl, CURLOPT_POSTFIELDS, payloadStr.c_str());
        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);
        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &responseData);
        curl_easy_setopt(curl, CURLOPT_TIMEOUT, 15L);
        curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT, 10L);

        CURLcode res = curl_easy_perform(curl);
        curl_slist_free_all(headers);
        curl_easy_cleanup(curl);

        if (res != CURLE_OK) {
            g_Logger.Log(LogType::Error, "Auth request failed: " + std::string(curl_easy_strerror(res)));
            return false;
        }

        try {
            response = json::parse(responseData);
            return true;
        }
        catch (...) {
            g_Logger.Log(LogType::Error, "Auth response parse failed");
            return false;
        }
    }

public:
    bool Login(const std::string& username, const std::string& password, const std::string& licenseKey) {
        g_Logger.Log(LogType::Info, "Authenticating...");

        json payload = {
            {"username", username},
            {"password", password},
            {"licenseKey", licenseKey},
            {"hwid", HWIDGenerator::Generate()}
        };

        json response;
        if (!MakeRequest("/auth/login", payload, response)) {
            g_Logger.Log(LogType::Error, "Authentication failed");
            return false;
        }

        bool success = response.value("success", false);
        if (!success) {
            std::string error = response.value("error", "Unknown error");
            g_Logger.Log(LogType::Error, "Authentication failed: " + error);
            return false;
        }

        m_SessionToken = response.value("token", "");
        m_IsAuthenticated = true;

        g_Config.GetConfig().user.username = username;
        g_Config.GetConfig().user.licenseKey = licenseKey;
        g_Config.GetConfig().user.plan = response.value("plan", "None");
        g_Config.GetConfig().user.expiry = response.value("expiry", "Never");
        g_Config.GetConfig().user.hwid = HWIDGenerator::Generate();
        g_Config.SaveSettings();

        g_Logger.Log(LogType::Success, "Authenticated as " + username);
        return true;
    }

    bool Register(const std::string& username, const std::string& password, const std::string& licenseKey) {
        g_Logger.Log(LogType::Info, "Registering account...");

        json payload = {
            {"username", username},
            {"password", password},
            {"licenseKey", licenseKey},
            {"hwid", HWIDGenerator::Generate()}
        };

        json response;
        if (!MakeRequest("/auth/register", payload, response)) {
            g_Logger.Log(LogType::Error, "Registration failed");
            return false;
        }

        bool success = response.value("success", false);
        if (!success) {
            std::string error = response.value("error", "Unknown error");
            g_Logger.Log(LogType::Error, "Registration failed: " + error);
            return false;
        }

        g_Logger.Log(LogType::Success, "Account registered successfully");
        return Login(username, password, licenseKey);
    }

    bool RedeemKey(const std::string& code) {
        if (!m_IsAuthenticated) {
            g_Logger.Log(LogType::Error, "Must be logged in to redeem");
            return false;
        }

        json payload = {
            {"token", m_SessionToken},
            {"code", code}
        };

        json response;
        if (!MakeRequest("/auth/redeem", payload, response)) {
            g_Logger.Log(LogType::Error, "Redeem failed");
            return false;
        }

        bool success = response.value("success", false);
        if (success) {
            g_Config.GetConfig().user.plan = response.value("plan", g_Config.GetConfig().user.plan);
            g_Config.GetConfig().user.expiry = response.value("expiry", g_Config.GetConfig().user.expiry);
            g_Config.SaveSettings();
            g_Logger.Log(LogType::Success, "Key redeemed successfully");
        } else {
            g_Logger.Log(LogType::Error, "Redeem failed: " + response.value("error", "Unknown"));
        }

        return success;
    }

    bool IsAuthenticated() const { return m_IsAuthenticated; }
    const std::string& GetToken() const { return m_SessionToken; }
};

inline AuthSystem g_Auth;

// ============================================================================
//  MEMORY INJECTOR - Manual Mapping
// ============================================================================
class MemoryInjector {
private:
    struct ManualMapData {
        LPVOID ImageBase;
        DWORD ImageSize;
        FARPROC LoadLibraryA;
        FARPROC GetProcAddress;
        FARPROC GetModuleHandleA;
    };

    typedef BOOL(WINAPI* DllMainFunc)(HINSTANCE hinstDLL, DWORD fdwReason, LPVOID lpReserved);

    static DWORD __stdcall LoaderThread(LPVOID parameter) {
        ManualMapData* data = (ManualMapData*)parameter;
        BYTE* pBase = (BYTE*)data->ImageBase;

        // Get PEB to resolve imports without LoadLibrary
        PPEB pPeb = (PPEB)__readgsqword(0x60);
        PPEB_LDR_DATA pLdr = pPeb->Ldr;

        // Parse and resolve imports
        IMAGE_DOS_HEADER* pDosHeader = (IMAGE_DOS_HEADER*)pBase;
        IMAGE_NT_HEADERS* pNtHeader = (IMAGE_NT_HEADERS*)(pBase + pDosHeader->e_lfanew);
        IMAGE_IMPORT_DESCRIPTOR* pImportDesc = (IMAGE_IMPORT_DESCRIPTOR*)(pBase + 
            pNtHeader->OptionalHeader.DataDirectory[IMAGE_DIRECTORY_ENTRY_IMPORT].VirtualAddress);

        while (pImportDesc->Name) {
            char* szModName = (char*)(pBase + pImportDesc->Name);
            HMODULE hMod = (HMODULE)GetModuleHandleA(szModName);

            if (!hMod) {
                hMod = (HMODULE)data->LoadLibraryA(szModName);
                if (!hMod) {
                    pImportDesc++;
                    continue;
                }
            }

            DWORD* pThunkRef = (DWORD*)(pBase + pImportDesc->OriginalFirstThunk);
            DWORD* pFuncRef = (DWORD*)(pBase + pImportDesc->FirstThunk);

            if (!pThunkRef) pThunkRef = pFuncRef;

            for (; *pThunkRef; pThunkRef++, pFuncRef++) {
                if (IMAGE_SNAP_BY_ORDINAL(*pThunkRef)) {
                    *pFuncRef = (DWORD)data->GetProcAddress(hMod, (LPCSTR)IMAGE_ORDINAL(*pThunkRef));
                } else {
                    IMAGE_IMPORT_BY_NAME* pImport = (IMAGE_IMPORT_BY_NAME*)(pBase + (*pThunkRef & 0x7FFFFFFF));
                    *pFuncRef = (DWORD)data->GetProcAddress(hMod, pImport->Name);
                }
            }
            pImportDesc++;
        }

        // Handle TLS callbacks
        IMAGE_TLS_DIRECTORY* pTLS = (IMAGE_TLS_DIRECTORY*)(pBase + 
            pNtHeader->OptionalHeader.DataDirectory[IMAGE_DIRECTORY_ENTRY_TLS].VirtualAddress);
        
        if (pTLS && pTLS->AddressOfCallBacks) {
            PIMAGE_TLS_CALLBACK* pCallback = (PIMAGE_TLS_CALLBACK*)pTLS->AddressOfCallBacks;
            while (*pCallback) {
                (*pCallback)(pBase, DLL_PROCESS_ATTACH, nullptr);
                pCallback++;
            }
        }

        // Call DllMain
        DllMainFunc pDllMain = (DllMainFunc)(pBase + pNtHeader->OptionalHeader.AddressOfEntryPoint);
        pDllMain((HINSTANCE)pBase, DLL_PROCESS_ATTACH, nullptr);

        HeapFree(GetProcessHeap(), 0, data);
        return 0;
    }

    static LRESULT __stdcall Shellcode(HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam) {
        return DefWindowProcA(hWnd, uMsg, wParam, lParam);
    }

public:
    bool Inject(DWORD targetPid) {
        g_Logger.Log(LogType::Info, "Locating embedded payload...");

        // Load embedded DLL from resources
        HRSRC hResource = FindResource(NULL, MAKEINTRESOURCE(IDR_PAYLOAD_DLL), "DLL");
        if (!hResource) {
            g_Logger.Log(LogType::Error, "Embedded payload not found");
            return false;
        }

        HGLOBAL hMemory = LoadResource(NULL, hResource);
        if (!hMemory) {
            g_Logger.Log(LogType::Error, "Failed to load resource");
            return false;
        }

        DWORD dllSize = SizeofResource(NULL, hResource);
        LPVOID dllData = LockResource(hMemory);

        g_Logger.Log(LogType::Success, "Payload located (" + std::to_string(dllSize) + " bytes)");

        // Validate PE header
        IMAGE_DOS_HEADER* pDosHeader = (IMAGE_DOS_HEADER*)dllData;
        if (pDosHeader->e_magic != IMAGE_DOS_SIGNATURE) {
            g_Logger.Log(LogType::Error, "Invalid PE signature");
            return false;
        }

        IMAGE_NT_HEADERS* pNtHeader = (IMAGE_NT_HEADERS*)((BYTE*)dllData + pDosHeader->e_lfanew);
        if (pNtHeader->Signature != IMAGE_NT_SIGNATURE) {
            g_Logger.Log(LogType::Error, "Invalid NT signature");
            return false;
        }

        // Open target process
        HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, targetPid);
        if (!hProcess) {
            g_Logger.Log(LogType::Error, "Failed to open process");
            return false;
        }

        g_Logger.Log(LogType::Success, "Process handle acquired");

        // Allocate memory for DLL
        DWORD imageSize = pNtHeader->OptionalHeader.SizeOfImage;
        LPVOID pRemoteBase = VirtualAllocEx(hProcess, nullptr, imageSize, 
            MEM_COMMIT | MEM_RESERVE, PAGE_EXECUTE_READWRITE);

        if (!pRemoteBase) {
            g_Logger.Log(LogType::Error, "Memory allocation failed");
            CloseHandle(hProcess);
            return false;
        }

        g_Logger.Log(LogType::Success, "Memory allocated at 0x" + 
            std::string(reinterpret_cast<char*>(pRemoteBase), 16));

        // Write headers
        SIZE_T bytesWritten;
        if (!WriteProcessMemory(hProcess, pRemoteBase, dllData, 
            pNtHeader->OptionalHeader.SizeOfHeaders, &bytesWritten)) {
            g_Logger.Log(LogType::Error, "Failed to write headers");
            VirtualFreeEx(hProcess, pRemoteBase, 0, MEM_RELEASE);
            CloseHandle(hProcess);
            return false;
        }

        // Write sections
        IMAGE_SECTION_HEADER* pSectionHeader = IMAGE_FIRST_SECTION(pNtHeader);
        for (int i = 0; i < pNtHeader->FileHeader.NumberOfSections; i++) {
            if (pSectionHeader[i].SizeOfRawData == 0) continue;

            LPVOID pSectionDest = (BYTE*)pRemoteBase + pSectionHeader[i].VirtualAddress;
            LPVOID pSectionSrc = (BYTE*)dllData + pSectionHeader[i].PointerToRawData;

            WriteProcessMemory(hProcess, pSectionDest, pSectionSrc, 
                pSectionHeader[i].SizeOfRawData, &bytesWritten);
        }

        g_Logger.Log(LogType::Success, "Sections mapped");

        // Allocate and write loader data
        ManualMapData* pData = (ManualMapData*)HeapAlloc(GetProcessHeap(), 0, sizeof(ManualMapData));
        pData->ImageBase = pRemoteBase;
        pData->ImageSize = imageSize;
        pData->LoadLibraryA = GetProcAddress(GetModuleHandleA("kernel32.dll"), "LoadLibraryA");
        pData->GetProcAddress = GetProcAddress(GetModuleHandleA("kernel32.dll"), "GetProcAddress");
        pData->GetModuleHandleA = GetProcAddress(GetModuleHandleA("kernel32.dll"), "GetModuleHandleA");

        LPVOID pRemoteData = VirtualAllocEx(hProcess, nullptr, sizeof(ManualMapData),
            MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
        WriteProcessMemory(hProcess, pRemoteData, pData, sizeof(ManualMapData), &bytesWritten);

        // Allocate shellcode and loader thread
        LPVOID pShellcode = VirtualAllocEx(hProcess, nullptr, 0x1000,
            MEM_COMMIT | MEM_RESERVE, PAGE_EXECUTE_READWRITE);
        WriteProcessMemory(hProcess, pShellcode, LoaderThread, 0x1000, &bytesWritten);

        // Create remote thread
        HANDLE hThread = CreateRemoteThread(hProcess, nullptr, 0,
            (LPTHREAD_START_ROUTINE)pShellcode, pRemoteData, 0, nullptr);

        if (!hThread) {
            g_Logger.Log(LogType::Error, "Remote thread creation failed");
            VirtualFreeEx(hProcess, pRemoteBase, 0, MEM_RELEASE);
            CloseHandle(hProcess);
            return false;
        }

        g_Logger.Log(LogType::Success, "Payload mapped successfully");
        g_Logger.Log(LogType::Success, "Hooks initializing...");

        WaitForSingleObject(hThread, 5000);
        CloseHandle(hThread);
        HeapFree(GetProcessHeap(), 0, pData);
        
        // Don't close process handle - payload needs it
        return true;
    }

    DWORD FindMinecraftProcess() {
        g_Logger.Log(LogType::Info, "Searching for Minecraft 1.8.9...");

        HANDLE hSnapshot = CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS, 0);
        if (hSnapshot == INVALID_HANDLE_VALUE) {
            g_Logger.Log(LogType::Error, "Failed to create process snapshot");
            return 0;
        }

        PROCESSENTRY32W pe32;
        pe32.dwSize = sizeof(PROCESSENTRY32W);

        DWORD pid = 0;
        if (Process32FirstW(hSnapshot, &pe32)) {
            do {
                std::wstring exeName = pe32.szExeFile;
                if (exeName == L"javaw.exe") {
                    // Verify it's Minecraft by checking window title
                    HWND hWindow = FindWindowW(L"GLFW30", nullptr);
                    if (!hWindow) hWindow = FindWindowW(L"LWJGL", nullptr);
                    if (!hWindow) hWindow = FindWindowW(nullptr, L"Minecraft 1.8.9");
                    
                    if (hWindow) {
                        DWORD windowPid;
                        GetWindowThreadProcessId(hWindow, &windowPid);
                        if (windowPid == pe32.th32ProcessID) {
                            pid = pe32.th32ProcessID;
                            break;
                        }
                    }
                }
            } while (Process32NextW(hSnapshot, &pe32));
        }

        CloseHandle(hSnapshot);

        if (pid) {
            g_Logger.Log(LogType::Success, "Minecraft found (PID: " + std::to_string(pid) + ")");
        } else {
            g_Logger.Log(LogType::Error, "Minecraft not found - launch 1.8.9 first");
        }

        return pid;
    }
};

inline MemoryInjector g_Injector;

// ============================================================================
//  IMGUI CUSTOM WIDGETS - Glassmorphism Style
// ============================================================================
namespace AurianWidgets {
    
    bool ToggleButton(const char* label, bool* v) {
        ImGuiWindow* window = ImGui::GetCurrentWindow();
        if (window->SkipItems) return false;

        ImGuiContext& g = *GImGui;
        const ImGuiStyle& style = g.Style;
        const ImGuiID id = window->GetID(label);
        const ImVec2 label_size = ImGui::CalcTextSize(label, nullptr, true);
        
        const float height = ImGui::GetFrameHeight() * 0.75f;
        const float width = height * 1.8f;
        const float radius = height * 0.5f;

        const ImVec2 pos = window->DC.CursorPos;
        const ImRect total_bb(pos, ImVec2(pos.x + width + style.ItemInnerSpacing.x + label_size.x, pos.y + height));
        
        ImGui::ItemSize(total_bb, style.FramePadding.y);
        if (!ImGui::ItemAdd(total_bb, id)) return false;

        bool hovered, held;
        bool pressed = ImGui::ButtonBehavior(total_bb, id, &hovered, &held);
        
        if (pressed) {
            *v = !(*v);
            ImGui::MarkItemEdited(id);
        }

        // Animation
        static std::map<ImGuiID, float> animStates;
        float& anim = animStates[id];
        float target = *v ? 1.0f : 0.0f;
        anim += (target - anim) * 0.15f;

        // Background
        ImU32 bgCol = *v ? AurianColors::ToggleOn : AurianColors::ToggleOff;
        if (hovered) {
            bgCol = *v ? IM_COL32(80, 160, 255, 255) : IM_COL32(65, 65, 80, 255);
        }

        ImDrawList* dl = window->DrawList;
        dl->AddRectFilled(pos, ImVec2(pos.x + width, pos.y + height), bgCol, radius);

        // Glow effect when on
        if (*v) {
            dl->AddRectFilledMultiColor(
                pos, ImVec2(pos.x + width, pos.y + height),
                IM_COL32(60, 140, 255, 30), IM_COL32(60, 140, 255, 10),
                IM_COL32(60, 140, 255, 10), IM_COL32(60, 140, 255, 30)
            );
        }

        // Knob
        float knobX = pos.x + radius + anim * (width - height);
        dl->AddCircleFilled(ImVec2(knobX, pos.y + radius), radius - 2, IM_COL32(240, 242, 248, 255));

        // Label
        ImVec2 labelPos = ImVec2(pos.x + width + style.ItemInnerSpacing.x, pos.y + (height - label_size.y) * 0.5f);
        dl->AddText(labelPos, *v ? AurianColors::AccentPrimary : AurianColors::TextSecondary, label);

        return pressed;
    }

    bool StyledSliderFloat(const char* label, float* v, float v_min, float v_max, const char* format = "%.1f") {
        ImGui::PushStyleColor(ImGuiCol_FrameBg, AurianColors::SliderTrack);
        ImGui::PushStyleColor(ImGuiCol_SliderGrab, AurianColors::SliderFill);
        ImGui::PushStyleColor(ImGuiCol_SliderGrabActive, AurianColors::AccentSecondary);
        ImGui::PushStyleColor(ImGuiCol_Border, AurianColors::InputBorder);
        ImGui::PushStyleVar(ImGuiStyleVar_FrameRounding, 4.0f);
        ImGui::PushStyleVar(ImGuiStyleVar_GrabRounding, 4.0f);
        
        bool changed = ImGui::SliderFloat(label, v, v_min, v_max, format);
        
        ImGui::PopStyleVar(2);
        ImGui::PopStyleColor(4);
        return changed;
    }

    bool StyledInputText(const char* label, char* buf, size_t buf_size, ImGuiInputTextFlags flags = 0) {
        ImGui::PushStyleColor(ImGuiCol_FrameBg, AurianColors::InputBg);
        ImGui::PushStyleColor(ImGuiCol_Border, AurianColors::InputBorder);
        ImGui::PushStyleColor(ImGuiCol_BorderActive, AurianColors::InputBorderActive);
        ImGui::PushStyleVar(ImGuiStyleVar_FrameRounding, 6.0f);
        ImGui::PushStyleVar(ImGuiStyleVar_FramePadding, ImVec2(10, 8));

        bool changed = ImGui::InputText(label, buf, buf_size, flags);

        ImGui::PopStyleVar(2);
        ImGui::PopStyleColor(3);
        return changed;
    }

    bool StyledButton(const char* label, ImVec2 size = ImVec2(0, 0), bool accent = true) {
        ImGui::PushStyleColor(ImGuiCol_Button, accent ? AurianColors::AccentPrimary : AurianColors::PanelBg);
        ImGui::PushStyleColor(ImGuiCol_ButtonHovered, accent ? AurianColors::AccentSecondary : IM_COL32(40, 40, 55, 255));
        ImGui::PushStyleColor(ImGuiCol_ButtonActive, accent ? IM_COL32(40, 100, 200, 255) : IM_COL32(50, 50, 65, 255));
        ImGui::PushStyleVar(ImGuiStyleVar_FrameRounding, 6.0f);
        ImGui::PushStyleVar(ImGuiStyleVar_FramePadding, ImVec2(16, 8));

        bool clicked = ImGui::Button(label, size);

        ImGui::PopStyleVar(2);
        ImGui::PopStyleColor(3);
        return clicked;
    }

    void SectionHeader(const char* text) {
        ImGui::Spacing();
        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::AccentPrimary);
        ImGui::SetFontScale(0.9f);
        ImGui::TextUnformatted(text);
        ImGui::SetFontScale(1.0f);
        ImGui::PopStyleColor();
        ImGui::Separator();
        ImGui::Spacing();
    }
}

// ============================================================================
//  NOTIFICATION SYSTEM (In-Loader)
// ============================================================================
struct Notification {
    std::string message;
    LogType type;
    float alpha = 1.0f;
    float timer = 4.0f;
    float slideOffset = 0.0f;
};

class NotificationManager {
private:
    std::vector<Notification> m_Notifications;
    static constexpr float NOTIFICATION_WIDTH = 280.0f;
    static constexpr float NOTIFICATION_HEIGHT = 40.0f;

public:
    void Push(const std::string& message, LogType type = LogType::Info) {
        Notification notif;
        notif.message = message;
        notif.type = type;
        notif.slideOffset = NOTIFICATION_WIDTH;
        m_Notifications.push_back(notif);
        
        if (m_Notifications.size() > 5) {
            m_Notifications.erase(m_Notifications.begin());
        }
    }

    void Render(float deltaTime) {
        if (m_Notifications.empty()) return;

        ImVec2 displaySize = ImGui::GetIO().DisplaySize;
        float startX = displaySize.x - NOTIFICATION_WIDTH - 20.0f;
        float startY = 20.0f;

        for (int i = m_Notifications.size() - 1; i >= 0; i--) {
            Notification& notif = m_Notifications[i];
            
            // Update
            notif.timer -= deltaTime;
            notif.slideOffset += (0.0f - notif.slideOffset) * 0.12f;
            
            if (notif.timer < 1.0f) {
                notif.alpha = notif.timer;
                notif.slideOffset += (NOTIFICATION_WIDTH - notif.slideOffset) * 0.08f;
            }

            if (notif.timer <= 0.0f) {
                m_Notifications.erase(m_Notifications.begin() + i);
                continue;
            }

            // Get color
            ImU32 bgColor, borderColor, textColor;
            switch (notif.type) {
                case LogType::Success:
                    bgColor = IM_COL32(20, 60, 40, (int)(220 * notif.alpha));
                    borderColor = IM_COL32(80, 200, 120, (int)(150 * notif.alpha));
                    textColor = IM_COL32(80, 200, 120, (int)(255 * notif.alpha));
                    break;
                case LogType::Error:
                    bgColor = IM_COL32(60, 20, 20, (int)(220 * notif.alpha));
                    borderColor = IM_COL32(255, 80, 80, (int)(150 * notif.alpha));
                    textColor = IM_COL32(255, 80, 80, (int)(255 * notif.alpha));
                    break;
                case LogType::Warning:
                    bgColor = IM_COL32(60, 50, 20, (int)(220 * notif.alpha));
                    borderColor = IM_COL32(255, 180, 60, (int)(150 * notif.alpha));
                    textColor = IM_COL32(255, 180, 60, (int)(255 * notif.alpha));
                    break;
                default:
                    bgColor = IM_COL32(20, 30, 60, (int)(220 * notif.alpha));
                    borderColor = IM_COL32(60, 140, 255, (int)(150 * notif.alpha));
                    textColor = IM_COL32(60, 140, 255, (int)(255 * notif.alpha));
            }

            float yPos = startY + i * (NOTIFICATION_HEIGHT + 8.0f);
            ImVec2 pos(startX + notif.slideOffset, yPos);

            ImDrawList* dl = ImGui::GetBackgroundDrawList();
            
            // Background with rounded corners
            dl->AddRectFilled(pos, ImVec2(pos.x + NOTIFICATION_WIDTH, pos.y + NOTIFICATION_HEIGHT), 
                bgColor, 8.0f);
            dl->AddRect(pos, ImVec2(pos.x + NOTIFICATION_WIDTH, pos.y + NOTIFICATION_HEIGHT), 
                borderColor, 8.0f, 0, 1.5f);

            // Text
            const char* prefix = "";
            switch (notif.type) {
                case LogType::Success: prefix = "[+] "; break;
                case LogType::Error: prefix = "[-] "; break;
                case LogType::Warning: prefix = "[!] "; break;
                default: prefix = "[*] "; break;
            }

            std::string fullText = prefix + notif.message;
            dl->AddText(ImVec2(pos.x + 12, pos.y + (NOTIFICATION_HEIGHT - ImGui::GetTextLineHeight()) * 0.5f), 
                textColor, fullText.c_str());
        }
    }
};

inline NotificationManager g_Notifications;

// ============================================================================
//  MODULE DEFINITIONS
// ============================================================================
enum class ModuleCategory { Combat, Render, Utility, Movement };

struct ModuleSetting {
    std::string name;
    enum Type { Toggle, Float, Int, String, Enum } type;
    float floatValue = 0.0f;
    float minFloat = 0.0f, maxFloat = 100.0f;
    int intValue = 0;
    std::string stringValue;
    std::vector<std::string> enumValues;
};

struct Module {
    std::string name;
    ModuleCategory category;
    std::vector<ModuleSetting> settings;
    int keybind = 0;
    bool enabled = false;

    ModuleSetting* FindSetting(const std::string& name) {
        for (auto& s : settings) {
            if (s.name == name) return &s;
        }
        return nullptr;
    }
};

class ModuleManager {
private:
    std::vector<Module> m_Modules;

    void InitializeModules() {
        // Combat
        Module aimAssist{ "AimAssist", ModuleCategory::Combat };
        aimAssist.settings = {
            {"Enabled", ModuleSetting::Toggle},
            {"Speed", ModuleSetting::Float, 50.0f, 0.0f, 100.0f},
            {"FOV", ModuleSetting::Float, 90.0f, 30.0f, 180.0f},
            {"Range", ModuleSetting::Float, 4.5f, 1.0f, 6.0f},
            {"Smoothing", ModuleSetting::Float, 65.0f, 1.0f, 100.0f}
        };
        m_Modules.push_back(aimAssist);

        Module autoClicker{ "AutoClicker", ModuleCategory::Combat };
        autoClicker.settings = {
            {"Min CPS", ModuleSetting::Float, 8.0f, 1.0f, 20.0f},
            {"Max CPS", ModuleSetting::Float, 12.0f, 1.0f, 20.0f},
            {"Jitter", ModuleSetting::Toggle},
            {"Randomize", ModuleSetting::Toggle}
        };
        m_Modules.push_back(autoClicker);

        Module reach{ "Reach", ModuleCategory::Combat };
        reach.settings = {
            {"Range", ModuleSetting::Float, 3.1f, 3.0f, 6.0f},
            {"Legit Mode", ModuleSetting::Toggle}
        };
        m_Modules.push_back(reach);

        Module velocity{ "Velocity", ModuleCategory::Combat };
        velocity.settings = {
            {"Horizontal", ModuleSetting::Float, 0.0f, 0.0f, 100.0f},
            {"Vertical", ModuleSetting::Float, 0.0f, 0.0f, 100.0f},
            {"Chance", ModuleSetting::Float, 100.0f, 0.0f, 100.0f}
        };
        m_Modules.push_back(velocity);

        Module wtap{ "WTap", ModuleCategory::Combat };
        wtap.settings = {
            {"Delay", ModuleSetting::Float, 150.0f, 50.0f, 500.0f},
            {"Chance", ModuleSetting::Float, 100.0f, 0.0f, 100.0f}
        };
        m_Modules.push_back(wtap);

        // Render
        Module esp{ "ESP", ModuleCategory::Render };
        esp.settings = {
            {"Mode", ModuleSetting::Enum, 0.0f}, // 0=Box, 1=Outline, 2=2D
            {"Players", ModuleSetting::Toggle},
            {"Mobs", ModuleSetting::Toggle},
            {"Items", ModuleSetting::Toggle}
        };
        esp.settings[0].enumValues = {"Box", "Outline", "2D"};
        m_Modules.push_back(esp);

        Module tracers{ "Tracers", ModuleCategory::Render };
        tracers.settings = {
            {"Width", ModuleSetting::Float, 1.5f, 0.5f, 5.0f},
            {"Color Mode", ModuleSetting::Enum, 0.0f}
        };
        tracers.settings[1].enumValues = {"Distance", "Health", "Static"};
        m_Modules.push_back(tracers);

        Module nametags{ "NameTags", ModuleCategory::Render };
        nametags.settings = {
            {"Show Health", ModuleSetting::Toggle},
            {"Show Armor", ModuleSetting::Toggle},
            {"Show Distance", ModuleSetting::Toggle},
            {"Scale", ModuleSetting::Float, 1.0f, 0.5f, 2.0f}
        };
        m_Modules.push_back(nametags);

        Module fullbright{ "Fullbright", ModuleCategory::Render };
        fullbright.settings = {
            {"Gamma", ModuleSetting::Float, 100.0f, 1.0f, 100.0f}
        };
        m_Modules.push_back(fullbright);

        Module search{ "Search", ModuleCategory::Render };
        search.settings = {
            {"Mode", ModuleSetting::Enum, 0.0f}
        };
        search.settings[0].enumValues = {"Diamond", "Emerald", "Gold", "Iron", "Spawner", "Chest"};
        m_Modules.push_back(search);

        // Utility
        Module scaffold{ "Scaffold", ModuleCategory::Utility };
        scaffold.settings = {
            {"Delay", ModuleSetting::Float, 50.0f, 0.0f, 200.0f},
            {"Tower Mode", ModuleSetting::Toggle},
            {"Expand", ModuleSetting::Float, 1.0f, 1.0f, 6.0f},
            {"SafeWalk", ModuleSetting::Toggle}
        };
        m_Modules.push_back(scaffold);

        Module chestSteal{ "ChestSteal", ModuleCategory::Utility };
        chestSteal.settings = {
            {"Delay", ModuleSetting::Float, 100.0f, 0.0f, 500.0f},
            {"Randomize", ModuleSetting::Toggle},
            {"Smart Steal", ModuleSetting::Toggle}
        };
        m_Modules.push_back(chestSteal);

        Module blink{ "Blink", ModuleCategory::Utility };
        blink.settings = {
            {"Max Packets", ModuleSetting::Int, 20, 1, 100},
            {"Visualize", ModuleSetting::Toggle}
        };
        m_Modules.push_back(blink);

        Module refill{ "Refill", ModuleCategory::Utility };
        refill.settings = {
            {"Health Trigger", ModuleSetting::Float, 8.0f, 1.0f, 20.0f},
            {"Potion Priority", ModuleSetting::Toggle}
        };
        m_Modules.push_back(refill);

        Module throwpot{ "Throwpot", ModuleCategory::Utility };
        throwpot.settings = {
            {"Delay", ModuleSetting::Float, 50.0f, 0.0f, 200.0f},
            {"Auto Switch Back", ModuleSetting::Toggle}
        };
        m_Modules.push_back(throwpot);

        // Movement
        Module sprint{ "Sprint", ModuleCategory::Movement };
        sprint.settings = {};
        m_Modules.push_back(sprint);

        Module speed{ "Speed", ModuleCategory::Movement };
        speed.settings = {
            {"Mode", ModuleSetting::Enum, 0.0f},
            {"Speed", ModuleSetting::Float, 1.5f, 0.5f, 5.0f}
        };
        speed.settings[0].enumValues = {"Vanilla", "Strafe", "LowHop"};
        m_Modules.push_back(speed);

        Module flight{ "Flight", ModuleCategory::Movement };
        flight.settings = {
            {"Speed", ModuleSetting::Float, 2.0f, 0.5f, 10.0f},
            {"AntiKick", ModuleSetting::Toggle}
        };
        m_Modules.push_back(flight);

        Module flyScaffold{ "Scaffold (Move)", ModuleCategory::Movement };
        flyScaffold.settings = {
            {"Use separate from Utility Scaffold", ModuleSetting::Toggle}
        };
        m_Modules.push_back(flyScaffold);

        // Load saved states
        LoadFromConfig();
    }

    void LoadFromConfig() {
        auto& modules = g_Config.GetConfig().modules;
        for (auto& mod : m_Modules) {
            if (modules.count(mod.name)) {
                mod.enabled = modules[mod.name].enabled;
                for (auto& setting : mod.settings) {
                    if (setting.type == ModuleSetting::Float) {
                        if (modules[mod.name].floatSettings.count(setting.name))
                            setting.floatValue = modules[mod.name].floatSettings[setting.name];
                    }
                    else if (setting.type == ModuleSetting::Int) {
                        if (modules[mod.name].intSettings.count(setting.name))
                            setting.intValue = modules[mod.name].intSettings[setting.name];
                    }
                    else if (setting.type == ModuleSetting::String || setting.type == ModuleSetting::Enum) {
                        if (modules[mod.name].stringSettings.count(setting.name))
                            setting.stringValue = modules[mod.name].stringSettings[setting.name];
                    }
                }
            }
        }

        auto& keybinds = g_Config.GetConfig().keybinds;
        for (auto& mod : m_Modules) {
            if (keybinds.count(mod.name))
                mod.keybind = keybinds[mod.name];
        }
    }

    void SaveToConfig() {
        auto& modules = g_Config.GetConfig().modules;
        for (auto& mod : m_Modules) {
            ModuleConfig& cfg = modules[mod.name];
            cfg.enabled = mod.enabled;
            for (auto& setting : mod.settings) {
                if (setting.type == ModuleSetting::Float)
                    cfg.floatSettings[setting.name] = setting.floatValue;
                else if (setting.type == ModuleSetting::Int)
                    cfg.intSettings[setting.name] = setting.intValue;
                else if (setting.type == ModuleSetting::String || setting.type == ModuleSetting::Enum)
                    cfg.stringSettings[setting.name] = setting.stringValue;
            }
        }

        auto& keybinds = g_Config.GetConfig().keybinds;
        for (auto& mod : m_Modules) {
            keybinds[mod.name] = mod.keybind;
        }

        g_Config.SaveSettings();
    }

public:
    void Initialize() {
        InitializeModules();
        g_Logger.Log(LogType::Success, "Module system initialized (" + 
            std::to_string(m_Modules.size()) + " modules)");
    }

    std::vector<Module>& GetModules() { return m_Modules; }
    
    std::vector<Module*> GetModulesByCategory(ModuleCategory cat) {
        std::vector<Module*> result;
        for (auto& mod : m_Modules) {
            if (mod.category == cat) result.push_back(&mod);
        }
        return result;
    }

    Module* FindModule(const std::string& name) {
        for (auto& mod : m_Modules) {
            if (mod.name == name) return &mod;
        }
        return nullptr;
    }

    void ToggleModule(const std::string& name) {
        if (Module* mod = FindModule(name)) {
            mod->enabled = !mod->enabled;
            SaveToConfig();
            
            if (mod->enabled)
                g_Notifications.Push(name + " Enabled", LogType::Success);
            else
                g_Notifications.Push(name + " Disabled", LogType::Info);
        }
    }

    void SaveAll() { SaveToConfig(); }
};

inline ModuleManager g_Modules;

// ============================================================================
//  FRIEND SYSTEM
// ============================================================================
class FriendSystem {
public:
    void AddFriend(const std::string& name) {
        auto& friends = g_Config.GetConfig().friends;
        if (std::find(friends.begin(), friends.end(), name) == friends.end()) {
            friends.push_back(name);
            g_Config.SaveSettings();
            g_Notifications.Push("Friend Added: " + name, LogType::Success);
            g_Logger.Log(LogType::Success, "Friend added: " + name);
        }
    }

    void RemoveFriend(const std::string& name) {
        auto& friends = g_Config.GetConfig().friends;
        auto it = std::find(friends.begin(), friends.end(), name);
        if (it != friends.end()) {
            friends.erase(it);
            g_Config.SaveSettings();
            g_Notifications.Push("Friend Removed: " + name, LogType::Warning);
            g_Logger.Log(LogType::Warning, "Friend removed: " + name);
        }
    }

    bool IsFriend(const std::string& name) {
        auto& friends = g_Config.GetConfig().friends;
        return std::find(friends.begin(), friends.end(), name) != friends.end();
    }

    const std::vector<std::string>& GetFriends() {
        return g_Config.GetConfig().friends;
    }
};

inline FriendSystem g_Friends;

