    bool CreateDeviceD3D() {
        DXGI_SWAP_CHAIN_DESC sd = {};
        sd.BufferCount = 2;
        sd.BufferDesc.Width = 0;
        sd.BufferDesc.Height = 0;
        sd.BufferDesc.Format = DXGI_FORMAT_R8G8B8A8_UNORM;
        sd.BufferDesc.RefreshRate.Numerator = 60;
        sd.BufferDesc.RefreshRate.Denominator = 1;
        sd.Flags = DXGI_SWAP_CHAIN_FLAG_ALLOW_MODE_SWITCH;
        sd.BufferUsage = DXGI_USAGE_RENDER_TARGET_OUTPUT;
        sd.OutputWindow = m_Hwnd;
        sd.SampleDesc.Count = 1;
        sd.SampleDesc.Quality = 0;
        sd.Windowed = TRUE;
        sd.SwapEffect = DXGI_SWAP_EFFECT_DISCARD;

        UINT createDeviceFlags = 0;
        D3D_FEATURE_LEVEL featureLevel;
        const D3D_FEATURE_LEVEL featureLevelArray[2] = { D3D_FEATURE_LEVEL_11_0, D3D_FEATURE_LEVEL_10_0 };

        HRESULT res = D3D11CreateDeviceAndSwapChain(nullptr, D3D_DRIVER_TYPE_HARDWARE, nullptr,
            createDeviceFlags, featureLevelArray, 2, D3D11_SDK_VERSION, &sd,
            &m_SwapChain, &m_Device, &featureLevel, &m_Context);

        if (res != S_OK) return false;
        return true;
    }

    void CreateRenderTarget() {
        ID3D11Texture2D* backBuffer;
        m_SwapChain->GetBuffer(0, IID_PPV_ARGS(&backBuffer));
        m_Device->CreateRenderTargetView(backBuffer, nullptr, &m_RenderTargetView);
        backBuffer->Release();
    }

    void CleanupDeviceD3D() {
        if (m_RenderTargetView) { m_RenderTargetView->Release(); m_RenderTargetView = nullptr; }
        if (m_SwapChain) { m_SwapChain->Release(); m_SwapChain = nullptr; }
        if (m_Context) { m_Context->Release(); m_Context = nullptr; }
        if (m_Device) { m_Device->Release(); m_Device = nullptr; }
    }

    void RenderSplashScreen(float deltaTime) {
        g_State.splashTimer += deltaTime;
        g_State.splashFade = std::min(g_State.splashFade + deltaTime * 1.5f, 1.0f);

        ImVec2 displaySize = ImGui::GetIO().DisplaySize;
        ImDrawList* dl = ImGui::GetBackgroundDrawList();

        // Background
        dl->AddRectFilled(ImVec2(0, 0), displaySize, IM_COL32(12, 12, 18, 255));

        // Center content
        float centerX = displaySize.x * 0.5f;
        float centerY = displaySize.y * 0.5f;

        // Logo
        if (g_State.logoTexture) {
            float logoScale = 0.6f;
            float logoW = g_State.logoWidth * logoScale;
            float logoH = g_State.logoHeight * logoScale;
            dl->AddImage(g_State.logoTexture, 
                ImVec2(centerX - logoW * 0.5f, centerY - logoH * 0.5f - 20),
                ImVec2(centerX + logoW * 0.5f, centerY + logoH * 0.5f - 20),
                IM_COL32(255, 255, 255, (int)(255 * g_State.splashFade)));
        }

        // "Initializing Aurian..." text
        const char* loadingText = "Initializing Aurian...";
        ImVec2 textSize = ImGui::CalcTextSize(loadingText);
        dl->AddText(ImVec2(centerX - textSize.x * 0.5f, centerY + 80),
            IM_COL32(140, 150, 170, (int)(255 * g_State.splashFade)), loadingText);

        // Loading spinner
        float spinnerAngle = g_State.splashTimer * 4.0f;
        float spinnerRadius = 12.0f;
        float spinnerX = centerX;
        float spinnerY = centerY + 115.0f;

        for (int i = 0; i < 8; i++) {
            float angle = spinnerAngle + i * (IM_PI * 2.0f / 8.0f);
            float x = spinnerX + cosf(angle) * spinnerRadius;
            float y = spinnerY + sinf(angle) * spinnerRadius;
            float alpha = (1.0f - (float)i / 8.0f) * g_State.splashFade;
            dl->AddCircleFilled(ImVec2(x, y), 2.5f, IM_COL32(60, 140, 255, (int)(alpha * 255)));
        }

        // Complete after 2.5 seconds
        if (g_State.splashTimer > 2.5f && !g_State.splashComplete) {
            g_State.splashComplete = true;
            g_State.currentState = AppState::Login;
            
            // Auto-fill if saved
            if (!g_Config.GetConfig().user.username.empty()) {
                strncpy(g_State.username, g_Config.GetConfig().user.username.c_str(), sizeof(g_State.username) - 1);
            }
            if (!g_Config.GetConfig().user.licenseKey.empty()) {
                strncpy(g_State.licenseKey, g_Config.GetConfig().user.licenseKey.c_str(), sizeof(g_State.licenseKey) - 1);
            }
        }
    }

    void RenderLoginScreen() {
        ImVec2 displaySize = ImGui::GetIO().DisplaySize;
        float windowW = 420.0f;
        float windowH = g_State.showRedeem ? 520.0f : 460.0f;
        ImVec2 windowPos((displaySize.x - windowW) * 0.5f, (displaySize.y - windowH) * 0.5f);

        ImGui::SetNextWindowPos(windowPos, ImGuiCond_Always);
        ImGui::SetNextWindowSize(ImVec2(windowW, windowH), ImGuiCond_Always);
        
        ImGui::Begin("##Login", nullptr, ImGuiWindowFlags_NoDecoration | ImGuiWindowFlags_NoMove | 
            ImGuiWindowFlags_NoResize | ImGuiWindowFlags_NoBringToFrontOnFocus);

        // Logo at top
        if (g_State.logoTexture) {
            float logoScale = 0.35f;
            float logoW = g_State.logoWidth * logoScale;
            float logoH = g_State.logoHeight * logoScale;
            ImGui::SetCursorPosX((windowW - logoW) * 0.5f);
            ImGui::Image(g_State.logoTexture, ImVec2(logoW, logoH));
        }

        ImGui::Spacing();
        ImGui::Spacing();

        // Title
        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextPrimary);
        ImGui::SetCursorPosX((windowW - ImGui::CalcTextSize("Aurian Client").x) * 0.5f);
        ImGui::SetFontScale(1.2f);
        ImGui::TextUnformatted("Aurian Client");
        ImGui::SetFontScale(1.0f);
        ImGui::PopStyleColor();

        ImGui::Spacing();
        ImGui::Separator();
        ImGui::Spacing();

        // Login form
        AurianWidgets::StyledInputText("Username", g_State.username, sizeof(g_State.username));
        AurianWidgets::StyledInputText("Password", g_State.password, sizeof(g_State.password), ImGuiInputTextFlags_Password);
        AurianWidgets::StyledInputText("License Key", g_State.licenseKey, sizeof(g_State.licenseKey));

        ImGui::Spacing();

        // Buttons
        float buttonWidth = (windowW - 48.0f) / 3.0f;
        
        if (AurianWidgets::StyledButton("Login", ImVec2(buttonWidth, 35))) {
            if (strlen(g_State.username) > 0 && strlen(g_State.password) > 0 && strlen(g_State.licenseKey) > 0) {
                if (g_Auth.Login(g_State.username, g_State.password, g_State.licenseKey)) {
                    g_State.currentState = AppState::Dashboard;
                    g_Notifications.Push("Welcome, " + std::string(g_State.username), LogType::Success);
                }
            } else {
                g_Notifications.Push("Fill in all fields", LogType::Warning);
            }
        }
        ImGui::SameLine();
        if (AurianWidgets::StyledButton("Register", ImVec2(buttonWidth, 35))) {
            if (strlen(g_State.username) > 0 && strlen(g_State.password) > 0 && strlen(g_State.licenseKey) > 0) {
                if (g_Auth.Register(g_State.username, g_State.password, g_State.licenseKey)) {
                    g_State.currentState = AppState::Dashboard;
                    g_Notifications.Push("Account created!", LogType::Success);
                }
            } else {
                g_Notifications.Push("Fill in all fields", LogType::Warning);
            }
        }
        ImGui::SameLine();
        if (AurianWidgets::StyledButton("Redeem", ImVec2(buttonWidth, 35), false)) {
            g_State.showRedeem = !g_State.showRedeem;
        }

        // Redeem section
        if (g_State.showRedeem) {
            ImGui::Spacing();
            AurianWidgets::SectionHeader("Redeem Key");
            AurianWidgets::StyledInputText("Redeem Code", g_State.redeemCode, sizeof(g_State.redeemCode));
            
            if (AurianWidgets::StyledButton("Redeem Code", ImVec2(-1, 32))) {
                if (strlen(g_State.redeemCode) > 0) {
                    g_Auth.RedeemKey(g_State.redeemCode);
                    memset(g_State.redeemCode, 0, sizeof(g_State.redeemCode));
                }
            }
        }

        // Footer
        ImGui::Spacing();
        ImGui::Spacing();
        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextDisabled);
        float footerWidth = ImGui::CalcTextSize("Powered by Aurian Studios").x;
        ImGui::SetCursorPosX((windowW - footerWidth) * 0.5f);
        ImGui::TextUnformatted("Powered by Aurian Studios");
        ImGui::PopStyleColor();

        ImGui::End();
    }

    void RenderDashboard() {
        ImVec2 displaySize = ImGui::GetIO().DisplaySize;
        float mainW = 850.0f;
        float mainH = 580.0f;
        ImVec2 mainPos((displaySize.x - mainW) * 0.5f, (displaySize.y - mainH) * 0.5f);

        ImGui::SetNextWindowPos(mainPos, ImGuiCond_Always);
        ImGui::SetNextWindowSize(ImVec2(mainW, mainH), ImGuiCond_Always);

        ImGui::Begin("##Dashboard", nullptr, ImGuiWindowFlags_NoDecoration | ImGuiWindowFlags_NoMove | ImGuiWindowFlags_NoResize);

        // Header with logo
        if (g_State.logoTexture) {
            float logoScale = 0.2f;
            float logoW = g_State.logoWidth * logoScale;
            float logoH = g_State.logoHeight * logoScale;
            ImGui::Image(g_State.logoTexture, ImVec2(logoW, logoH));
            ImGui::SameLine();
        }

        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextPrimary);
        ImGui::SetFontScale(1.1f);
        ImGui::TextUnformatted("Aurian Client");
        ImGui::SetFontScale(0.8f);
        ImGui::SameLine();
        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextDisabled);
        ImGui::TextUnformatted("v1.0");
        ImGui::PopStyleColor();
        ImGui::PopStyleColor();
        ImGui::SetFontScale(1.0f);

        // User info in header
        ImGui::SameLine(ImGui::GetWindowWidth() - 300);
        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextSecondary);
        ImGui::Text("User: %s", g_Config.GetConfig().user.username.c_str());
        ImGui::SameLine(ImGui::GetWindowWidth() - 150);
        ImGui::Text("Plan: %s", g_Config.GetConfig().user.plan.c_str());
        ImGui::PopStyleColor();

        ImGui::Separator();

        // Tab bar
        const char* tabs[] = { "Combat", "Render", "Utility", "Movement", "Profiles", "Settings" };
        for (int i = 0; i < IM_ARRAYSIZE(tabs); i++) {
            if (i > 0) ImGui::SameLine();
            
            bool isActive = g_State.activeTab == i;
            if (isActive) {
                ImGui::PushStyleColor(ImGuiCol_Button, AurianColors::TabActive);
                ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::AccentPrimary);
            } else {
                ImGui::PushStyleColor(ImGuiCol_Button, ImVec4(0, 0, 0, 0));
                ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextSecondary);
            }
            
            if (ImGui::Button(tabs[i], ImVec2(120, 30))) {
                g_State.activeTab = i;
            }
            ImGui::PopStyleColor(2);
        }

        ImGui::Spacing();

        // Content area
        ImGui::BeginChild("##Content", ImVec2(0, 0), false);
        
        switch (g_State.activeTab) {
            case 0: RenderCombatTab(); break;
            case 1: RenderRenderTab(); break;
            case 2: RenderUtilityTab(); break;
            case 3: RenderMovementTab(); break;
            case 4: RenderProfilesTab(); break;
            case 5: RenderSettingsTab(); break;
        }

        ImGui::EndChild();

        // Footer
        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextDisabled);
        float footerWidth = ImGui::CalcTextSize("Powered by Aurian Studios").x;
        ImGui::SetCursorPosX((mainW - footerWidth) * 0.5f);
        ImGui::TextUnformatted("Powered by Aurian Studios");
        ImGui::PopStyleColor();

        ImGui::End();
    }

    void RenderModuleList(ModuleCategory category) {
        auto modules = g_Modules.GetModulesByCategory(category);
        for (auto* mod : modules) {
            AurianWidgets::ToggleButton(mod->name.c_str(), &mod->enabled);
            
            if (mod->enabled) {
                ImGui::Indent(20.0f);
                for (auto& setting : mod->settings) {
                    switch (setting.type) {
                        case ModuleSetting::Toggle:
                            AurianWidgets::ToggleButton(setting.name.c_str(), &setting.floatValue > 0.5f ? 
                                (bool*)&setting.floatValue : nullptr);
                            break;
                        case ModuleSetting::Float:
                            AurianWidgets::StyledSliderFloat(setting.name.c_str(), 
                                &setting.floatValue, setting.minFloat, setting.maxFloat);
                            break;
                        case ModuleSetting::Int:
                            AurianWidgets::StyledSliderFloat(setting.name.c_str(), 
                                (float*)&setting.intValue, (float)setting.intValue, (float)setting.intValue + 100, "%.0f");
                            break;
                        case ModuleSetting::Enum:
                            if (ImGui::BeginCombo(setting.name.c_str(), 
                                setting.enumValues.empty() ? "" : setting.enumValues[setting.intValue].c_str())) {
                                for (int i = 0; i < setting.enumValues.size(); i++) {
                                    bool selected = setting.intValue == i;
                                    if (ImGui::Selectable(setting.enumValues[i].c_str(), selected)) {
                                        setting.intValue = i;
                                    }
                                    if (selected) ImGui::SetItemDefaultFocus();
                                }
                                ImGui::EndCombo();
                            }
                            break;
                        case ModuleSetting::String:
                            AurianWidgets::StyledInputText(setting.name.c_str(), 
                                setting.stringValue.data(), setting.stringValue.capacity());
                            break;
                    }
                }
                ImGui::Unindent(20.0f);
            }
            ImGui::Spacing();
        }
    }

    void RenderCombatTab() {
        AurianWidgets::SectionHeader("Combat Modules");
        RenderModuleList(ModuleCategory::Combat);
    }

    void RenderRenderTab() {
        AurianWidgets::SectionHeader("Render Modules");
        RenderModuleList(ModuleCategory::Render);
    }

    void RenderUtilityTab() {
        AurianWidgets::SectionHeader("Utility Modules");
        RenderModuleList(ModuleCategory::Utility);
    }

    void RenderMovementTab() {
        AurianWidgets::SectionHeader("Movement Modules");
        RenderModuleList(ModuleCategory::Movement);
    }

    void RenderProfilesTab() {
        AurianWidgets::SectionHeader("Profile Management");

        // Active profile
        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextSecondary);
        ImGui::Text("Active: %s", g_Config.GetConfig().activeProfile.c_str());
        ImGui::PopStyleColor();

        ImGui::Spacing();

        // Profile name input
        AurianWidgets::StyledInputText("Profile Name", g_State.profileName, sizeof(g_State.profileName));

        ImGui::Spacing();

        // Profile buttons
        if (AurianWidgets::StyledButton("Save Current", ImVec2(150, 30))) {
            if (strlen(g_State.profileName) > 0) {
                g_Modules.SaveAll();
                g_Config.SaveProfile(g_State.profileName);
            }
        }
        ImGui::SameLine();
        if (AurianWidgets::StyledButton("Load Profile", ImVec2(150, 30), false)) {
            if (strlen(g_State.profileName) > 0) {
                g_Config.LoadProfile(g_State.profileName);
                g_Modules.Initialize(); // Reload module states
            }
        }

        ImGui::Spacing();
        ImGui::Spacing();

        // Profile list
        AurianWidgets::SectionHeader("Saved Profiles");
        auto profiles = g_Config.GetProfileList();
        for (const auto& profile : profiles) {
            bool isSelected = profile == g_Config.GetConfig().activeProfile;
            if (isSelected) {
                ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::AccentPrimary);
            }
            
            if (ImGui::Selectable(profile.c_str(), isSelected)) {
                g_Config.LoadProfile(profile);
                g_Modules.Initialize();
            }
            
            if (isSelected) {
                ImGui::PopStyleColor();
            }
        }

        if (profiles.empty()) {
            ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextDisabled);
            ImGui::TextUnformatted("No saved profiles");
            ImGui::PopStyleColor();
        }

        ImGui::Spacing();
        ImGui::Spacing();

        // Friends section
        AurianWidgets::SectionHeader("Friends List");
        AurianWidgets::StyledInputText("Player Name", g_State.friendName, sizeof(g_State.friendName));
        
        if (AurianWidgets::StyledButton("Add Friend", ImVec2(120, 28))) {
            if (strlen(g_State.friendName) > 0) {
                g_Friends.AddFriend(g_State.friendName);
                memset(g_State.friendName, 0, sizeof(g_State.friendName));
            }
        }

        ImGui::Spacing();

        auto& friends = g_Friends.GetFriends();
        for (int i = 0; i < friends.size(); i++) {
            ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::Success);
            ImGui::Bullet();
            ImGui::SameLine();
            ImGui::TextUnformatted(friends[i].c_str());
            ImGui::PopStyleColor();
            
            ImGui::SameLine(ImGui::GetWindowWidth() - 80);
            std::string removeLabel = "Remove##" + std::to_string(i);
            if (AurianWidgets::StyledButton(removeLabel.c_str(), ImVec2(70, 22), false)) {
                g_Friends.RemoveFriend(friends[i]);
                break;
            }
        }
    }

    void RenderSettingsTab() {
        AurianWidgets::SectionHeader("User Information");

        ImGui::PushStyleColor(ImGuiCol_Text, AurianColors::TextSecondary);
        ImGui::Text("Username: %s", g_Config.GetConfig().user.username.c_str());
        ImGui::Text("Plan: %s", g_Config.GetConfig().user.plan.c_str());
        ImGui::Text("Expires: %s", g_Config.GetConfig().user.expiry.c_str());
        ImGui::Text("HWID: %s", g_Config.GetConfig().user.hwid.empty() ? "Unbound" : "Bound");
        ImGui::Text("Status: %s", g_State.isInjected ? "Injected" : "Ready");
        ImGui::PopStyleColor();

        ImGui::Spacing();
        AurianWidgets::SectionHeader("Injection");

        if (AurianWidgets::StyledButton(g_State.isInjected ? "Already Injected" : "Inject into Minecraft", 
            ImVec2(200, 35), !g_State.isInjected)) {
            std::thread([]{
                g_State.mcPid = g_Injector.FindMinecraftProcess();
                if (g_State.mcPid) {
                    if (g_Injector.Inject(g_State.mcPid)) {
                        g_State.isInjected = true;
                        g_Logger.Log(LogType::Success, "Client ready");
                        g_Notifications.Push("Client injected successfully", LogType::Success);
                    }
                }
            }).detach();
        }

        ImGui::Spacing();
        AurianWidgets::SectionHeader("Logs");

        ImGui::BeginChild("##LogScroll", ImVec2(0, 200), true);
        g_Logger.Render();
        ImGui::EndChild();

        if (AurianWidgets::StyledButton("Clear Logs", ImVec2(100, 25), false)) {
            g_Logger.Clear();
        }
    }

public:
    bool Initialize(HWND hwnd) {
        m_Hwnd = hwnd;
        
        if (!CreateDeviceD3D()) return false;
        CreateRenderTarget();

        IMGUI_CHECKVERSION();
        ImGui::CreateContext();
        ImGuiIO& io = ImGui::GetIO();
        io.IniFilename = nullptr;

        ImGui_ImplWin32_Init(hwnd);
        ImGui_ImplDX11_Init(m_Device, m_Context);

        ApplyAurianStyle();

        // Load logo texture
        g_State.logoTexture = ResourceLoader::LoadTextureFromResource(m_Device, IDR_AURIAN_PNG, 
            g_State.logoWidth, g_State.logoHeight);

        return true;
    }

    void Render() {
        auto now = std::chrono::steady_clock::now();
        float deltaTime = std::chrono::duration<float>(now - m_LastFrame).count();
        m_LastFrame = now;

        ImGui_ImplDX11_NewFrame();
        ImGui_ImplWin32_NewFrame();
        ImGui::NewFrame();

        switch (g_State.currentState) {
            case AppState::Splash:
                RenderSplashScreen(deltaTime);
                break;
            case AppState::Login:
                RenderLoginScreen();
                break;
            case AppState::Dashboard:
                RenderDashboard();
                break;
        }

        // Notifications overlay
        g_Notifications.Render(deltaTime);

        ImGui::Render();

        const float clearColor[4] = { 0.047f, 0.047f, 0.071f, 1.0f };
        m_Context->OMSetRenderTargets(1, &m_RenderTargetView, nullptr);
        m_Context->ClearRenderTargetView(m_RenderTargetView, clearColor);
        ImGui_ImplDX11_RenderDrawData(ImGui::GetDrawData());

        m_SwapChain->Present(1, 0);
    }

    void Shutdown() {
        ImGui_ImplDX11_Shutdown();
        ImGui_ImplWin32_Shutdown();
        ImGui::DestroyContext();
        CleanupDeviceD3D();
    }

    bool IsRunning() const { return m_Running; }
    void Stop() { m_Running = false; }
};

// ============================================================================
//  WINDOW PROCEDURE
// ============================================================================
static AurianGUI* g_GUI = nullptr;

LRESULT WINAPI WndProc(HWND hWnd, UINT msg, WPARAM wParam, LPARAM lParam) {
    if (ImGui_ImplWin32_WndProcHandler(hWnd, msg, wParam, lParam))
        return true;

    switch (msg) {
        case WM_SIZE:
            if (g_GUI && wParam != SIZE_MINIMIZED) {
                // Handle resize if needed
            }
            return 0;
        case WM_SYSCOMMAND:
            if ((wParam & 0xfff0) == SC_KEYMENU)
                return 0;
            break;
        case WM_DESTROY:
            PostQuitMessage(0);
            return 0;
    }
    return DefWindowProc(hWnd, msg, wParam, lParam);
}

// ============================================================================
//  ENTRY POINT
// ============================================================================
int WINAPI WinMain(HINSTANCE hInstance, HINSTANCE hPrevInstance, LPSTR lpCmdLine, int nCmdShow) {
    // Set console for debugging (remove in release)
    // AllocConsole();
    // freopen("CONOUT$", "w", stdout);

    // Initialize systems
    g_Config.Initialize();
    g_Modules.Initialize();

    // Create window class
    WNDCLASSEXW wc = {};
    wc.cbSize = sizeof(WNDCLASSEXW);
    wc.style = CS_CLASSDC;
    wc.lpfnWndProc = WndProc;
    wc.hInstance = hInstance;
    wc.lpszClassName = L"AurianLoaderClass";
    wc.hIcon = LoadIcon(hInstance, MAKEINTRESOURCE(IDR_LOGO_PNG));
    wc.hIconSm = LoadIcon(hInstance, MAKEINTRESOURCE(IDR_LOGO_PNG));
    RegisterClassExW(&wc);

    // Create window
    HWND hwnd = CreateWindowExW(
        0, L"AurianLoaderClass", L"Aurian Loader",
        WS_POPUP | WS_VISIBLE,
        (GetSystemMetrics(SM_CXSCREEN) - 860) / 2,
        (GetSystemMetrics(SM_CYSCREEN) - 600) / 2,
        860, 600,
        nullptr, nullptr, wc.hInstance, nullptr
    );

    // Initialize GUI
    AurianGUI gui;
    g_GUI = &gui;
    
    if (!gui.Initialize(hwnd)) {
        MessageBoxA(nullptr, "Failed to initialize renderer", "Aurian Error", MB_OK | MB_ICONERROR);
        return 1;
    }

    // Main loop
    MSG msg = {};
    while (gui.IsRunning()) {
        while (PeekMessage(&msg, nullptr, 0U, 0U, PM_REMOVE)) {
            TranslateMessage(&msg);
            DispatchMessage(&msg);
            if (msg.message == WM_QUIT)
                gui.Stop();
        }
        if (!gui.IsRunning()) break;
        gui.Render();
    }

    gui.Shutdown();
    DestroyWindow(hwnd);
    UnregisterClassW(wc.lpszClassName, wc.hInstance);

    return 0;
}
